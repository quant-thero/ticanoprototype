# =====================================================================
#  TICANO — ENV TEMPLATE   (.env.example)  →  SAFE TO COMMIT TO GITHUB
#  Copy this to .env.local and fill in real values:
#      cp .env.example .env.local
#  .env.local is git-ignored and is what the app actually reads.
#  Vite only exposes variables prefixed with VITE_ to the browser.
# =====================================================================

# Supabase project URL — https://<project-ref>.supabase.co
# (Project Settings → Data API → Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase publishable (anon) key — public-safe, protected by Row Level Security.
# (Project Settings → API keys → Publishable key)
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
